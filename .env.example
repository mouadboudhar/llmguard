# ==============================================
# QUICKSTART — minimum required before running
# ==============================================
# 1. Copy this file: cp .env.example .env
# 2. Set a secure dashboard token below
# 3. Run: docker compose up
# ==============================================

LLMGUARD_DASHBOARD_TOKEN=change-this-before-deploying

# LLM Provider (default: OpenAI)
# Provider for default route: openai/anthropic/ollama/mistral/grok/nvidia
LLMGUARD_UPSTREAM_URL=https://api.openai.com
LLMGUARD_PROVIDER=openai

# Rate limiting defaults (applied to all keys unless overridden per-key)
LLMGUARD_DEFAULT_RPM=60
LLMGUARD_DEFAULT_RPH=1000
LLMGUARD_DEFAULT_RPD=10000

# Output guard action: redact | block | log_only
LLMGUARD_OUTPUT_GUARD_ACTION=redact

# Translation timeout in seconds
LLMGUARD_TRANSLATE_TIMEOUT=1.0

# Default user clearance for RAG filtering
LLMGUARD_DEFAULT_CLEARANCE=INTERNAL

# ----------------------------------------------
# Optional
# ----------------------------------------------
# Database path. In Docker, compose sets this to /app/data/llmguard.db;
# for a local (non-Docker) run the default below is used.
# LLMGUARD_DB_PATH=./llmguard.db

# Comma-separated CORS origins allowed to call the API cross-origin.
# Not needed when the dashboard is served via nginx/Vite (same-origin).
# LLMGUARD_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
