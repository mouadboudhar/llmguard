# Upstream LLM provider base URL (the adapter appends the provider path)
# OpenAI:    https://api.openai.com
# Anthropic: https://api.anthropic.com
# Ollama:    http://localhost:11434
# Grok (xAI)
# https://api.x.ai/v1/chat/completions
#
# NVIDIA NIM
# https://integrate.api.nvidia.com/v1/chat/completions
LLMGUARD_UPSTREAM_URL=https://api.openai.com
# Provider for default route: openai/anthropic/ollama/mistral/grok/nvidia
LLMGUARD_PROVIDER=openai
LLMGUARD_DB_PATH=./llmguard.db
# Output guard action on PII/secret detection: redact (default) | block | log_only
LLMGUARD_OUTPUT_GUARD_ACTION=redact
# Default rate limits applied to all keys unless overridden
LLMGUARD_DEFAULT_RPM=60
LLMGUARD_DEFAULT_RPH=1000
LLMGUARD_DEFAULT_RPD=10000
# Token for dashboard WebSocket and audit-API authentication
LLMGUARD_DASHBOARD_TOKEN=change-this-before-deploying
